# MySQL
MYSQL_DATABASE=meistertrack
MYSQL_USER=meistertrack
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# Backend
DATABASE_URL=mysql+pymysql://meistertrack:change_me@localhost:3306/meistertrack
JWT_SECRET_KEY=change_me_jwt_secret

# Google OAuth (학교 Google Workspace 계정 전용 로그인)
# Client ID 발급 전까지는 GOOGLE_OAUTH_MOCK=true로 두면 로그인 화면에서 이메일 직접입력으로 테스트 가능
# 발급 후: GOOGLE_OAUTH_MOCK=false로 바꾸고 GOOGLE_CLIENT_ID만 채우면 됨 (client secret 불필요 - ID 토큰 검증 방식)
GOOGLE_OAUTH_MOCK=true
GOOGLE_CLIENT_ID=
ALLOWED_EMAIL_DOMAIN=bssm.hs.kr
# mock 로그인은 이메일만 알면 그 계정으로 로그인되므로 접근 코드 필수.
# 비어있으면 mock 로그인이 완전히 차단된다(fail-closed) — 값을 넣어야 mock 로그인을 쓸 수 있음.
# 생성: openssl rand -hex 16
MOCK_LOGIN_SECRET=

# NVIDIA NIM (build.nvidia.com, OpenAI 호환 엔드포인트)
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_NAME=nvidia/nvidia-nemotron-nano-9b-v2

# Cloudflare Tunnel (meistertrack.imjemin.co.kr)
# 로컬 관리형 터널이라 대시보드로 라우트 설정 불가 -> config.yml + credentials.json 방식 사용
# ./cloudflared-config.yml, ./cloudflared-creds.json 파일을 Pi에 직접 생성 (git에는 올리지 않음)
